# ==========================================================
# CouncilIA â€” Environment Variables (.env.example)
# ==========================================================
# Copy this to .env.local and fill in your values.
#   cp .env.example .env.local
# ==========================================================

# ---------- Next.js ----------
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Supabase (required) ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GRAPHOS_TENANT_ID=your-tenant-or-org-id
GRAPHOS_ORG_ID=your-governance-org-id

# ---------- Stripe (optional â€” billing) ----------
# Comment these out if you don't need billing. The build will fail without STRIPE_SECRET_KEY.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID=price_...

# ---------- LLM Providers ----------
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=CouncilIA
MISTRAL_API_KEY=your-mistral-key

# ---------- Upstash / QStash (queue + rate limit) ----------
QSTASH_TOKEN=your-qstash-token
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---------- GitHub (repo sync / PR) ----------
GITHUB_TOKEN=ghp_...

# ---------- Security ----------
INTERNAL_WORKER_SECRET=generate-a-random-64-char-secret
AUDIT_SECRET=generate-a-random-64-char-secret
IP_SALT=generate-a-random-salt-string

# ---------- Feature Flags ----------
ENABLE_DEBUG_ENDPOINTS=false
ENABLE_GITHUB_PR_WRITE=false

