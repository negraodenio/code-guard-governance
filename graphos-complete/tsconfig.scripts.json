{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2017",
    "lib": ["es2017", "dom"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "noEmit": false,
    "isolatedModules": false,
    "incremental": false,
    "downlevelIteration": true
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules"]
}
