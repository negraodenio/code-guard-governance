# ===========================================
# CODEGUARD AI - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# SUPABASE (Required for Credits & Auth)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# OPENROUTER (Required for AI Analysis)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3-opus

# STRIPE (Optional - For Development)
STRIPE_PAYMENT_LINK=https://buy.stripe.com/...

# EXTENSION SETTINGS
CODEGUARD_DEBUG_MODE=false
CODEGUARD_TELEMETRY=true

# API SECURITY (Required for REST API access)
CODEGUARD_API_KEYS=api-key-1,api-key-2,api-key-3

# API v1 (SDK) SECURITY (Required - FAIL-CLOSED)
# Used by /api/v1/scan, /api/v1/patch, /api/v1/credits
# Must be a long random secret; rotate if exposed.
CODEGUARD_API_SECRET=change-me-to-a-long-random-secret

# SERVER CONFIGURATION (For API mode)
PORT=3000
TRANSPORT_MODE=sse

# MCP/REST hardening (recommended for production)
# Limit JSON payload size (prevents abuse / memory pressure)
CODEGUARD_REQUEST_BODY_LIMIT=256kb
# Restrict filesystem reads to this root (for MCP tools that accept file paths)
CODEGUARD_WORKSPACE_ROOT=.
# Comma-separated allowlist of browser origins for CORS (only enforced in NODE_ENV=production)
CODEGUARD_CORS_ORIGINS=https://your-admin-ui.example.com

# RAG/Memory persistence (default OFF)
# If enabled, CodeGuard may store code chunks in Supabase for retrieval.
CODEGUARD_MEMORY_PERSIST=false
