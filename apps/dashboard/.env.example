# Talk-to-Governance LLM (optional — works without it)
# Provider: openai | deepseek | ollama | none
LLM_PROVIDER=none
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
